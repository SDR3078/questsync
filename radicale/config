# Radicale 3.x — Prove-0 baseline configuration.
# Deliberately minimal and insecure (auth=none): we are proving the ENVIRONMENT
# (networking, the CalDAV task-list collection, a client round-trip), not our
# code and not security. Auth gets hardened in a later step.

[server]
hosts = 0.0.0.0:5232

[auth]
# Multi-user: DAV login = Habitica User ID, password = Habitica API token,
# validated live by our plugin (radicale_auth.py). Login results are cached so
# we don't re-hit Habitica's /user endpoint on every DAV request.
type = questsync.radicale_auth
cache_logins = True
cache_successful_logins_expiry = 300
cache_failed_logins_expiry = 5

[storage]
# QuestSync's filesystem-free backend. Radicale imports the class named
# `Storage` from this dotted module path (must be importable via PYTHONPATH).
type = questsync.radicale_storage

[rights]
# Each user may read/write only their own /<user>/... collections.
type = owner_only

[web]
# Built-in web UI at http://localhost:5232/.web/ for eyeballing collections.
type = internal

[logging]
level = info
