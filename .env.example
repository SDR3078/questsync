# QuestSync configuration. The SERVER needs NO Habitica credentials — each user
# authenticates with their own Habitica User ID + API token as DAV credentials.

# 1 = offline demo (fixture data, any login accepted). Empty for real use.
QUESTSYNC_DEMO=

# Which task lists to expose (implemented: todos, dailys).
QUESTSYNC_TASK_TYPES=todos,dailys

# Seconds to cache each user's task snapshot (Habitica limit is 30 req/60s).
QUESTSYNC_CACHE_TTL=30

# Seconds to trust a validated login before re-checking against Habitica.
QUESTSYNC_LOGIN_TTL=300

# Optional: fixed x-client author id (defaults to each user's own id).
QUESTSYNC_CLIENT_AUTHOR=

# Access gate — who may log in. Default (empty) = allowall: anyone with valid
# Habitica creds (today's behavior). Set "allowlist" or "http" to restrict.
QUESTSYNC_ACCESS_POLICY=
# allowlist: comma-separated Habitica User IDs, and/or a file (one id per line,
# re-read live — e.g. a mounted ConfigMap — so edits apply without a restart).
QUESTSYNC_ALLOWLIST=
QUESTSYNC_ALLOWLIST_FILE=
# http: ask an external endpoint "GET <url>?user=<id>" (200=allow, 403/404=deny,
# anything else/unreachable = transient retry). For a hosted/paid control plane.
QUESTSYNC_ACCESS_HTTP_URL=

# --- for scripts/live-multiuser-verify.sh ONLY (your own creds, used as a test
# DAV login; NOT read by the server). From https://habitica.com/user/settings/api
HABITICA_USER_ID=
HABITICA_API_TOKEN=
