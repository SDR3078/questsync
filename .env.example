# Copy to .env (git-ignored) and fill in to sync your REAL Habitica account.
# Leave HABITICA_USER_ID / HABITICA_API_TOKEN empty to run in offline DEMO mode.
# Get your credentials at: https://habitica.com/user/settings/api

HABITICA_USER_ID=
HABITICA_API_TOKEN=

# Optional. x-client header; defaults to "<HABITICA_USER_ID>-questsync".
HABITICA_CLIENT=

# Which task types to expose (implemented: todos, dailys).
QUESTSYNC_TASK_TYPES=todos,dailys

# Seconds to cache the Habitica snapshot (Habitica limit is 30 requests/60s).
QUESTSYNC_CACHE_TTL=30
